# Database
DATABASE_URL="postgresql://user:password@localhost:5432/signal_watcher"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
LOG_QUERIES=false

# Security
ALLOWED_ORIGINS=http://localhost:3000
API_KEY=secret-key-here

# Redis (optional — falls back to in-memory cache)
REDIS_URL=redis://localhost:6379

# AI Provider
AI_MODE=mock
# AI_MODE=openai
# OPENAI_API_KEY=sk-...
